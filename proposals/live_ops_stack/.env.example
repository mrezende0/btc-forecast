# Copie pra .env e preencha. NÃO commitar .env.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Binance Testnet USDM futures — gera em https://testnet.binancefuture.com
BINANCE_TESTNET_KEY=
BINANCE_TESTNET_SECRET=

# Grafana
GRAFANA_ADMIN_PASSWORD=changeme_strong

# Executor (paper | dryrun | live)
MODE=paper
NOTIONAL_USD=100
LEVERAGE=3
STOP_PCT=0.025
TARGET_PCT=0.035

# Live mode requer DUPLA confirmação. NÃO ative sem 3-6 meses paper válidos.
# LIVE_CONFIRMED=YES
